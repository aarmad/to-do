{
  "name": "neo-list",
  "version": "1.0.0",
  "description": "Neo-List — Application de gestion de tâches (néo-brutaliste)",
  "main": "electron/main.js",
  "author": {
    "name": "aarmad",
    "email": ""
  },
  "homepage": "https://github.com/aarmad/to-do",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --x64",
    "build:portable": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win portable --x64",
    "build:nsis": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis --x64",
    "build:all": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --linux --mac",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^29.3.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.aarmad.neo-list",
    "productName": "Neo-List",
    "copyright": "Copyright © 2025 aarmad",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/electron-updater/**/*"
    ],
    "files": [
      "**/*",
      "!dist/**/*",
      "!.github/**/*",
      "!.gitignore",
      "!README*",
      "!*.md"
    ],
    "win": {
      "sign": null,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Neo-List",
      "installerLanguages": [
        "fr_FR",
        "en_US"
      ],
      "language": "1036"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "aarmad",
        "repo": "to-do",
        "releaseType": "release"
      }
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
